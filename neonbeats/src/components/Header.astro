---
---

<header class="encabezado">
  <div class="contenedor">
    <a href="/" class="logo" aria-label="Ir al inicio de Neon Beats">
      <div class="circulo">
        <span class="titulo">NEON</span>
        <span class="titulo">BEATS</span>
        <span class="subtitulo">FESTIVAL</span>
      </div>
    </a>

    <nav class="menu" aria-label="Navegacion principal">
      <a href="#festival">Festival</a>
      <a href="#artistas">Artistas</a>
      <a href="#actividades">Actividades</a>
      <a href="#entradas">Entradas</a>
    </nav>

    <button class="idioma" type="button" aria-label="Idioma actual ESP">
      <span class="bandera" aria-hidden="true"></span>
      <span>ESP</span>
    </button>
  </div>
</header>

<style>
  .encabezado {
    width: 100%;
    position: sticky;
    top: 0;
    z-index: 1000;
    background: linear-gradient(90deg, #1c031b, #520b4a, #0e3c47, #031f30);
    border-bottom: 1px solid rgba(255, 255, 255, 0.18);
    box-shadow: 0 8px 26px rgba(0, 0, 0, 0.35);
  }

  .contenedor {
    width: min(1200px, calc(100% - 2rem));
    margin: 0 auto;
    min-height: 96px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: rem;
    padding: 0.75rem 0;
  }

  .logo {
    text-decoration: none;
    flex-shrink: 0;
  }

  .circulo {
    width: 86px;
    height: 86px;
    border-radius: 50%;
    background: radial-gradient(circle at 30% 30%, #2e0760, #0a0114 72%);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    border: 2px solid rgba(0, 224, 255, 0.4);
    box-shadow: 0 0 18px rgba(0, 224, 255, 0.28);
  }

  .titulo {
    font-size: 1.05rem;
    line-height: 1;
    font-weight: 800;
    color: #00e0ff;
    letter-spacing: 0.04em;
  }

  .subtitulo {
    margin-top: 0.16rem;
    font-size: 0.66rem;
    letter-spacing: 0.15em;
    color: #fff;
  }

  .menu {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: clamp(1rem, 5vw, 6rem);
    flex: 1;
  }

  .menu a {
    color: #fff;
    text-decoration: none;
    font-size: clamp(1.1rem, 1.6vw, 1.6rem);
    letter-spacing: 0.03em;
    transition: color 0.2s ease, text-shadow 0.2s ease;
  }

  .menu a:hover,
  .menu a:focus-visible {
    color: #00e0ff;
    text-shadow: 0 0 10px rgba(0, 224, 255, 0.75);
    outline: none;
  }

  .idioma {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.45rem;
    min-width: 96px;
    padding: 0.6rem 1rem;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.26);
    background: rgba(60, 8, 72, 0.9);
    color: #fff;
    font-size: 1.05rem;
    font-weight: 700;
    cursor: pointer;
    transition: transform 0.2s ease, background-color 0.2s ease;
  }

  .idioma:hover,
  .idioma:focus-visible {
    transform: translateY(-1px);
    background: rgba(75, 10, 88, 0.95);
    outline: none;
  }

  .bandera {
    width: 18px;
    height: 18px;
    border-radius: 50%;
    background: linear-gradient(red 33%, yellow 33%, yellow 66%, red 66%);
  }

  @media (max-width: 900px) {
    .contenedor {
      min-height: auto;
      display: grid;
      grid-template-columns: 1fr auto;
      grid-template-areas:
        "logo idioma"
        "menu menu";
      row-gap: 0.85rem;
      column-gap: 0.75rem;
      padding: 0.75rem 0 1rem;
    }

    .logo {
      grid-area: logo;
    }

    .menu {
      grid-area: menu;
      justify-content: space-between;
      gap: 0.85rem;
    }

    .idioma {
      grid-area: idioma;
      justify-self: end;
      min-width: 88px;
      padding: 0.55rem 0.85rem;
      font-size: 0.95rem;
    }
  }

  @media (max-width: 580px) {
    .contenedor {
      width: min(1200px, calc(100% - 1rem));
    }

    .circulo {
      width: 74px;
      height: 74px;
    }

    .titulo {
      font-size: 0.93rem;
    }

    .subtitulo {
      font-size: 0.56rem;
    }

    .menu {
      justify-content: flex-start;
      overflow-x: auto;
      white-space: nowrap;
      padding-bottom: 0.25rem;
      scrollbar-width: none;
    }

    .menu::-webkit-scrollbar {
      display: none;
    }

    .menu a {
      font-size: 1rem;
      flex-shrink: 0;
    }
  }
</style>
